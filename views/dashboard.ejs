<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container-fluid px-3 px-lg-4 py-4">
  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h2 fw-700 mb-1"><i class="bi bi-speedometer2 text-danger me-2"></i>Live Dashboard</h1>
      <p class="text-muted small mb-0">Real-time disaster response monitoring</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
        <span class="status-dot bg-success me-1"></span>Live
      </span>
      <% if (user && user.role === 'admin') { %>
        <a href="/alerts/broadcast" class="btn btn-danger btn-sm rounded-pill">
          <i class="bi bi-broadcast me-1"></i>Broadcast Alert
        </a>
      <% } %>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="row g-3 mb-4" id="statsGrid">
    <div class="col-6 col-md-4 col-lg-2">
      <div class="stat-card bg-danger text-white rounded-4 p-3 h-100">
        <div class="stat-icon mb-2"><i class="bi bi-exclamation-triangle-fill fs-4"></i></div>
        <div class="stat-value fw-700 fs-3 lh-1" id="db-active"><%= stats.activeIncidents %></div>
        <div class="stat-label small opacity-80 mt-1">Active Incidents</div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <div class="stat-card bg-warning text-dark rounded-4 p-3 h-100">
        <div class="stat-icon mb-2"><i class="bi bi-radioactive fs-4"></i></div>
        <div class="stat-value fw-700 fs-3 lh-1" id="db-critical"><%= stats.criticalIncidents %></div>
        <div class="stat-label small opacity-80 mt-1">Critical</div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <div class="stat-card bg-success text-white rounded-4 p-3 h-100">
        <div class="stat-icon mb-2"><i class="bi bi-check-circle-fill fs-4"></i></div>
        <div class="stat-value fw-700 fs-3 lh-1" id="db-resolved"><%= stats.resolvedToday %></div>
        <div class="stat-label small opacity-80 mt-1">Resolved Today</div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <div class="stat-card bg-primary text-white rounded-4 p-3 h-100">
        <div class="stat-icon mb-2"><i class="bi bi-house-heart-fill fs-4"></i></div>
        <div class="stat-value fw-700 fs-3 lh-1" id="db-shelters"><%= stats.openShelters %></div>
        <div class="stat-label small opacity-80 mt-1">Open Shelters</div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <div class="stat-card bg-orange text-white rounded-4 p-3 h-100">
        <div class="stat-icon mb-2"><i class="bi bi-people-fill fs-4"></i></div>
        <div class="stat-value fw-700 fs-3 lh-1"><%= stats.totalAffected.toLocaleString('en-IN') %></div>
        <div class="stat-label small opacity-80 mt-1">People Affected</div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <div class="stat-card bg-info text-white rounded-4 p-3 h-100">
        <div class="stat-icon mb-2"><i class="bi bi-shield-fill-check fs-4"></i></div>
        <div class="stat-value fw-700 fs-3 lh-1"><%= stats.activeRescue %></div>
        <div class="stat-label small opacity-80 mt-1">Rescue Ops</div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Incidents Table -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 px-4">
          <h5 class="fw-600 mb-0"><i class="bi bi-list-ul me-2 text-danger"></i>Recent Incidents</h5>
          <a href="/incidents" class="btn btn-outline-danger btn-sm rounded-pill">View All</a>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-4 border-0 small fw-600 text-muted text-uppercase">Incident</th>
                  <th class="border-0 small fw-600 text-muted text-uppercase">Location</th>
                  <th class="border-0 small fw-600 text-muted text-uppercase">Severity</th>
                  <th class="border-0 small fw-600 text-muted text-uppercase">Status</th>
                  <th class="pe-4 border-0"></th>
                </tr>
              </thead>
              <tbody id="incidentTable">
              <% incidents.slice(0,12).forEach(inc => { %>
                <tr>
                  <td class="ps-4">
                    <div class="fw-500 small"><%= inc.title %></div>
                    <div class="text-muted" style="font-size:0.75rem;"><%= inc.type %> • <%= new Date(inc.created_at).toLocaleDateString('en-IN') %></div>
                  </td>
                  <td class="small text-muted"><i class="bi bi-geo-alt me-1"></i><%= inc.state || inc.location.split(',')[0] %></td>
                  <td><span class="badge severity-badge-<%= inc.severity %>"><%= inc.severity %></span></td>
                  <td><span class="badge status-badge-<%= inc.status %>"><%= inc.status %></span></td>
                  <td class="pe-4"><a href="/incidents/<%= inc.id %>" class="btn btn-sm btn-outline-secondary rounded-pill py-0 px-2" style="font-size:0.75rem;">View</a></td>
                </tr>
              <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Alerts + Rescue Ops -->
    <div class="col-lg-4">
      <!-- Active Alerts -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 px-4 pb-2">
          <h6 class="fw-600 mb-0"><i class="bi bi-bell-fill me-2 text-warning"></i>Active Alerts</h6>
          <span class="badge bg-danger rounded-pill" id="db-alerts"><%= stats.activeAlerts %></span>
        </div>
        <div class="card-body p-3 pt-0" id="alertsList">
          <% if (alerts.length === 0) { %>
            <p class="text-muted small text-center py-3">No active alerts</p>
          <% } %>
          <% alerts.slice(0,5).forEach(a => { %>
            <div class="alert-item rounded-3 p-3 mb-2 alert-severity-<%= a.severity %>">
              <div class="fw-600 small"><%= a.title %></div>
              <div class="text-muted" style="font-size:0.72rem;" class="mt-1"><%= a.message.slice(0, 80) %>...</div>
              <% if (a.state) { %><span class="badge bg-light text-dark" style="font-size:0.65rem;"><%= a.state %></span><% } %>
            </div>
          <% }) %>
          <a href="/alerts" class="btn btn-outline-warning btn-sm w-100 rounded-pill mt-1">All Alerts →</a>
        </div>
      </div>

      <!-- Rescue Operations -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-2">
          <h6 class="fw-600 mb-0"><i class="bi bi-shield-fill-check me-2 text-success"></i>Rescue Operations</h6>
        </div>
        <div class="card-body p-3 pt-0">
          <% rescueOps.forEach(op => { %>
          <div class="rescue-op-item rounded-3 p-3 mb-2 bg-success-subtle">
            <div class="fw-600 small"><%= op.team_name %></div>
            <div class="text-muted" style="font-size:0.72rem;"><%= op.incident_title %></div>
            <div class="d-flex gap-1 mt-1 flex-wrap">
              <span class="badge bg-success text-white" style="font-size:0.65rem;"><%= op.team_type %></span>
              <span class="badge bg-primary-subtle text-primary" style="font-size:0.65rem;"><%= op.personnel %> personnel</span>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <!-- Incident breakdown cards -->
  <div class="row g-3 mt-2">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm rounded-4 p-4">
        <h6 class="fw-600 mb-3">Incidents by Type</h6>
        <div class="d-flex flex-wrap gap-2">
          <% byType.forEach(t => { %>
          <div class="type-pill d-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-light">
            <span><%= t.type === 'flood' ? '🌊' : t.type === 'earthquake' ? '🏚️' : t.type === 'cyclone' ? '🌀' : t.type === 'fire' ? '🔥' : t.type === 'landslide' ? '⛰️' : '⚠️' %></span>
            <span class="small fw-500 text-capitalize"><%= t.type %></span>
            <span class="badge bg-danger rounded-pill"><%= t.count %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm rounded-4 p-4">
        <h6 class="fw-600 mb-3">Incidents by Severity</h6>
        <% bySeverity.forEach(s => { %>
        <div class="mb-2">
          <div class="d-flex justify-content-between mb-1">
            <span class="small fw-500 text-capitalize"><%= s.severity %></span>
            <span class="small text-muted"><%= s.count %></span>
          </div>
          <div class="progress rounded-pill" style="height:8px;">
            <div class="progress-bar bg-<%= s.severity === 'critical' ? 'danger' : s.severity === 'high' ? 'warning' : s.severity === 'medium' ? 'primary' : 'success' %>"
              style="width: <%= Math.min((s.count / 10) * 100, 100) %>%"></div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- Auto-refresh with SSE -->
<script>
  if (typeof EventSource !== 'undefined') {
    const evtSrc = new EventSource('/alerts/stream');
    evtSrc.onmessage = function(e) {
      const data = JSON.parse(e.data);
      if (data.stats) {
        document.getElementById('db-active').textContent = data.stats.activeIncidents;
        document.getElementById('db-alerts').textContent = data.stats.activeAlerts;
        document.getElementById('db-shelters').textContent = data.stats.openShelters;
        document.getElementById('db-resolved').textContent = data.stats.resolvedToday;
      }
    };
  }
</script>

<%- include('partials/footer') %>
