<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container-fluid px-3 px-lg-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h2 fw-700 mb-1"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Incidents</h1>
      <p class="text-muted small mb-0">All reported emergencies across India</p>
    </div>
    <a href="/incidents/report" class="btn btn-danger rounded-pill px-4">
      <i class="bi bi-plus-circle-fill me-2"></i>Report New
    </a>
  </div>

  <% if (reported) { %>
  <div class="alert alert-success alert-dismissible rounded-4 border-0 shadow-sm mb-4">
    <i class="bi bi-check-circle-fill me-2"></i>Incident reported successfully. Authorities have been notified.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <!-- Filters -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
      <form method="GET" action="/incidents" class="row g-2 align-items-end">
        <div class="col-6 col-md-3">
          <label class="form-label small fw-500 mb-1">Type</label>
          <select name="type" class="form-select form-select-sm rounded-pill">
            <option value="">All Types</option>
            <% ['flood','earthquake','cyclone','fire','landslide','industrial'].forEach(t => { %>
              <option value="<%= t %>" <%= filters.type === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-md-3">
          <label class="form-label small fw-500 mb-1">Severity</label>
          <select name="severity" class="form-select form-select-sm rounded-pill">
            <option value="">All Severity</option>
            <% ['critical','high','medium','low'].forEach(s => { %>
              <option value="<%= s %>" <%= filters.severity === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-md-3">
          <label class="form-label small fw-500 mb-1">State</label>
          <select name="state" class="form-select form-select-sm rounded-pill">
            <option value="">All States</option>
            <% states.forEach(s => { %>
              <option value="<%= s.state %>" <%= filters.state === s.state ? 'selected' : '' %>><%= s.state %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-md-3">
          <label class="form-label small fw-500 mb-1">Status</label>
          <select name="status" class="form-select form-select-sm rounded-pill">
            <option value="">All Status</option>
            <% ['active','monitoring','resolved'].forEach(s => { %>
              <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12 col-md-auto d-flex gap-2">
          <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3">Filter</button>
          <a href="/incidents" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Reset</a>
        </div>
      </form>
    </div>
  </div>

  <!-- Incident Cards -->
  <% if (incidents.length === 0) { %>
    <div class="text-center py-5">
      <div class="fs-1 mb-3">📋</div>
      <h4 class="fw-600 text-muted">No incidents found</h4>
      <p class="text-muted">Try adjusting your filters or <a href="/incidents/report" class="text-danger">report a new incident</a></p>
    </div>
  <% } %>
  <div class="row g-3">
    <% incidents.forEach(inc => { %>
    <div class="col-md-6 col-xl-4">
      <div class="card incident-card h-100 border-0 shadow-sm rounded-4 hover-lift">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div class="d-flex align-items-center gap-2">
              <span class="fs-4"><%= inc.type === 'flood' ? '🌊' : inc.type === 'earthquake' ? '🏚️' : inc.type === 'cyclone' ? '🌀' : inc.type === 'fire' ? '🔥' : inc.type === 'landslide' ? '⛰️' : '⚠️' %></span>
              <span class="badge bg-secondary-subtle text-secondary text-capitalize"><%= inc.type %></span>
            </div>
            <span class="badge severity-badge-<%= inc.severity %>"><%= inc.severity.toUpperCase() %></span>
          </div>
          <h5 class="fw-600 mb-2 lh-sm"><%= inc.title %></h5>
          <p class="text-muted small mb-2"><i class="bi bi-geo-alt-fill me-1 text-danger"></i><%= inc.location %><% if (inc.state) { %>, <strong><%= inc.state %></strong><% } %></p>
          <% if (inc.description) { %>
            <p class="text-muted small mb-3 lh-base line-clamp-2"><%= inc.description %></p>
          <% } %>
          <div class="d-flex flex-wrap gap-2 mb-3">
            <% if (inc.affected_people > 0) { %>
              <span class="badge bg-light text-dark border"><i class="bi bi-people me-1"></i><%= inc.affected_people.toLocaleString('en-IN') %> affected</span>
            <% } %>
            <% if (inc.responders > 0) { %>
              <span class="badge bg-success-subtle text-success border-success border"><i class="bi bi-shield-fill me-1"></i><%= inc.responders %> responders</span>
            <% } %>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <span class="badge status-badge-<%= inc.status %> px-3 py-2"><%= inc.status %></span>
            <div class="d-flex gap-2 align-items-center">
              <span class="text-muted" style="font-size:0.72rem;"><%= new Date(inc.created_at).toLocaleDateString('en-IN') %></span>
              <a href="/incidents/<%= inc.id %>" class="btn btn-sm btn-outline-danger rounded-pill">Details →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
