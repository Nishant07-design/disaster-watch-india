<%- include('../partials/head') %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<%- include('../partials/navbar') %>

<div class="container-fluid px-3 px-lg-4 py-4">
  <div class="mb-4">
    <a href="/incidents" class="btn btn-outline-secondary btn-sm rounded-pill mb-3">
      <i class="bi bi-arrow-left me-1"></i>Back to Incidents
    </a>
    <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
      <span class="fs-2"><%= incident.type === 'flood' ? '🌊' : incident.type === 'earthquake' ? '🏚️' : incident.type === 'cyclone' ? '🌀' : incident.type === 'fire' ? '🔥' : incident.type === 'landslide' ? '⛰️' : '⚠️' %></span>
      <h1 class="h2 fw-700 mb-0"><%= incident.title %></h1>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <span class="badge severity-badge-<%= incident.severity %> px-3 py-2"><%= incident.severity.toUpperCase() %></span>
      <span class="badge status-badge-<%= incident.status %> px-3 py-2"><%= incident.status.toUpperCase() %></span>
      <span class="badge bg-secondary-subtle text-secondary px-3 py-2 text-capitalize"><%= incident.type %></span>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-8">
      <!-- Details Card -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
          <h5 class="fw-600 mb-4">Incident Details</h5>
          <div class="row g-3">
            <div class="col-sm-6">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">Location</label>
              <p class="fw-500 mb-0"><i class="bi bi-geo-alt-fill text-danger me-1"></i><%= incident.location %></p>
            </div>
            <% if (incident.district) { %>
            <div class="col-sm-6">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">District</label>
              <p class="fw-500 mb-0"><%= incident.district %></p>
            </div>
            <% } %>
            <% if (incident.state) { %>
            <div class="col-sm-6">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">State</label>
              <p class="fw-500 mb-0"><%= incident.state %></p>
            </div>
            <% } %>
            <div class="col-sm-6">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">Reported</label>
              <p class="fw-500 mb-0"><%= new Date(incident.created_at).toLocaleString('en-IN') %></p>
            </div>
            <% if (incident.reporter_name) { %>
            <div class="col-sm-6">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">Reported By</label>
              <p class="fw-500 mb-0"><i class="bi bi-person-circle me-1"></i><%= incident.reporter_name %></p>
            </div>
            <% } %>
            <% if (incident.affected_people > 0) { %>
            <div class="col-sm-6">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">People Affected</label>
              <p class="fw-500 mb-0 text-danger"><i class="bi bi-people-fill me-1"></i><%= incident.affected_people.toLocaleString('en-IN') %></p>
            </div>
            <% } %>
            <% if (incident.responders > 0) { %>
            <div class="col-sm-6">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">Responders</label>
              <p class="fw-500 mb-0 text-success"><i class="bi bi-shield-fill-check me-1"></i><%= incident.responders %> deployed</p>
            </div>
            <% } %>
            <% if (incident.description) { %>
            <div class="col-12">
              <label class="text-muted small text-uppercase fw-600 tracking-wide">Description</label>
              <p class="fw-400 mb-0 lh-base"><%= incident.description %></p>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Map if coordinates available -->
      <% if (incident.lat && incident.lng) { %>
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
          <h5 class="fw-600 mb-3">Location on Map</h5>
          <div id="incidentMap" class="rounded-3 overflow-hidden" style="height:300px;"></div>
        </div>
      </div>
      <% } %>

      <!-- Rescue Operations -->
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <h5 class="fw-600 mb-3"><i class="bi bi-shield-fill-check text-success me-2"></i>Rescue Operations</h5>
          <% if (ops.length === 0) { %>
            <p class="text-muted small">No rescue operations logged for this incident yet.</p>
          <% } %>
          <% ops.forEach(op => { %>
          <div class="card border-0 bg-success-subtle rounded-3 mb-2 p-3">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h6 class="fw-600 mb-1"><%= op.team_name %></h6>
                <div class="d-flex gap-2 flex-wrap">
                  <span class="badge bg-success"><%= op.team_type %></span>
                  <span class="badge bg-primary-subtle text-primary"><%= op.personnel %> personnel</span>
                  <span class="badge bg-warning-subtle text-warning"><%= op.status %></span>
                </div>
              </div>
              <span class="text-muted small"><%= new Date(op.created_at).toLocaleDateString('en-IN') %></span>
            </div>
            <% if (op.notes) { %>
              <p class="small text-muted mb-0 mt-2"><%= op.notes %></p>
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
      <!-- Actions (admin) -->
      <% if (user && user.role === 'admin') { %>
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
          <h6 class="fw-600 mb-3">Admin Actions</h6>
          <form action="/incidents/<%= incident.id %>/status" method="POST" class="d-flex gap-2">
            <select name="status" class="form-select form-select-sm rounded-3">
              <option value="active" <%= incident.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="monitoring" <%= incident.status === 'monitoring' ? 'selected' : '' %>>Monitoring</option>
              <option value="resolved" <%= incident.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
            </select>
            <button type="submit" class="btn btn-danger btn-sm rounded-3 text-nowrap">Update</button>
          </form>
        </div>
      </div>
      <% } %>

      <!-- Quick Action Buttons -->
      <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
          <h6 class="fw-600 mb-3">Emergency Actions</h6>
          <div class="d-grid gap-2">
            <a href="tel:112" class="btn btn-danger rounded-3 fw-600">
              <i class="bi bi-telephone-fill me-2"></i>Call 112 (Emergency)
            </a>
            <a href="tel:01124363260" class="btn btn-outline-danger rounded-3">
              <i class="bi bi-shield-fill me-2"></i>Call NDRF
            </a>
            <a href="/shelters" class="btn btn-outline-primary rounded-3">
              <i class="bi bi-house-heart-fill me-2"></i>Find Nearest Shelter
            </a>
            <a href="/ai-guide" class="btn btn-outline-warning rounded-3">
              <i class="bi bi-robot me-2"></i>AI Safety Guide
            </a>
          </div>
        </div>
      </div>

      <!-- Safety Tips -->
      <div class="card border-0 bg-warning-subtle rounded-4">
        <div class="card-body p-4">
          <h6 class="fw-600 mb-3"><i class="bi bi-lightbulb-fill text-warning me-1"></i>Safety Reminder</h6>
          <ul class="small mb-0 ps-3">
            <% if (incident.type === 'flood') { %>
              <li>Move to higher ground immediately</li>
              <li>Avoid walking in floodwater</li>
              <li>Turn off electricity at main switch</li>
            <% } else if (incident.type === 'earthquake') { %>
              <li>DROP, COVER and HOLD ON</li>
              <li>Stay away from windows</li>
              <li>Expect aftershocks</li>
            <% } else if (incident.type === 'cyclone') { %>
              <li>Stay indoors in the strongest part</li>
              <li>Do not go out during the eye</li>
              <li>Stock up on water and food</li>
            <% } else if (incident.type === 'fire') { %>
              <li>Evacuate immediately via stairs</li>
              <li>Stay low if there is smoke</li>
              <li>Call fire brigade: 101</li>
            <% } else { %>
              <li>Follow official instructions</li>
              <li>Stay away from affected areas</li>
              <li>Contact NDRF: 011-24363260</li>
            <% } %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (incident.lat && incident.lng) { %>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const imap = L.map('incidentMap').setView([<%= incident.lat %>, <%= incident.lng %>], 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(imap);
  L.marker([<%= incident.lat %>, <%= incident.lng %>]).addTo(imap)
    .bindPopup('<b><%= incident.title %></b>').openPopup();
</script>
<% } %>

<%- include('../partials/footer') %>
