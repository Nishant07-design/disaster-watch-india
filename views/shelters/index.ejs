<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container-fluid px-3 px-lg-4 py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h2 fw-700 mb-1"><i class="bi bi-house-heart-fill text-success me-2"></i>Emergency Shelters</h1>
      <p class="text-muted small mb-0">Find and track relief camp availability across India</p>
    </div>
    <a href="/map" class="btn btn-outline-primary btn-sm rounded-pill">
      <i class="bi bi-map-fill me-1"></i>View on Map
    </a>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-card bg-primary text-white rounded-4 p-3">
        <div class="fw-700 fs-3"><%= stats.total %></div>
        <div class="small opacity-80">Total Shelters</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card bg-success text-white rounded-4 p-3">
        <div class="fw-700 fs-3"><%= stats.open %></div>
        <div class="small opacity-80">Open Now</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card bg-info text-white rounded-4 p-3">
        <div class="fw-700 fs-3"><%= stats.totalCapacity.toLocaleString('en-IN') %></div>
        <div class="small opacity-80">Total Capacity</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card bg-warning text-dark rounded-4 p-3">
        <div class="fw-700 fs-3"><%= stats.totalOccupancy.toLocaleString('en-IN') %></div>
        <div class="small opacity-80">Current Occupancy</div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
      <form method="GET" class="row g-2 align-items-end">
        <div class="col-md-4">
          <label class="form-label small fw-500 mb-1">State</label>
          <select name="state" class="form-select form-select-sm rounded-pill">
            <option value="">All States</option>
            <% states.forEach(s => { %>
              <option value="<%= s.state %>" <%= filters.state === s.state ? 'selected' : '' %>><%= s.state %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label small fw-500 mb-1">Status</label>
          <select name="status" class="form-select form-select-sm rounded-pill">
            <option value="">All</option>
            <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
            <option value="full" <%= filters.status === 'full' ? 'selected' : '' %>>Full</option>
          </select>
        </div>
        <div class="col-md-auto d-flex gap-2">
          <button type="submit" class="btn btn-success btn-sm rounded-pill px-3">Filter</button>
          <a href="/shelters" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Reset</a>
        </div>
      </form>
    </div>
  </div>

  <!-- Shelter Cards -->
  <div class="row g-3">
    <% shelters.forEach(s => { %>
    <div class="col-md-6 col-xl-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 hover-lift">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div class="shelter-icon bg-success-subtle text-success rounded-3 p-2 fs-4">🏠</div>
            <span class="badge <%= s.status === 'open' ? 'bg-success' : 'bg-secondary' %> px-3 py-2 rounded-pill">
              <%= s.status === 'open' ? '✓ Open' : '✗ Full' %>
            </span>
          </div>
          <h5 class="fw-600 mb-1 lh-sm"><%= s.name %></h5>
          <p class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i><%= s.address %></p>
          <% if (s.district || s.state) { %>
            <p class="text-muted small mb-3"><i class="bi bi-map me-1"></i><%= [s.district, s.state].filter(Boolean).join(', ') %></p>
          <% } %>

          <!-- Capacity bar -->
          <div class="mb-3">
            <div class="d-flex justify-content-between mb-1">
              <span class="small fw-500">Occupancy</span>
              <span class="small text-muted"><%= s.current_occupancy %>/<%= s.capacity %></span>
            </div>
            <div class="progress rounded-pill" style="height:8px;">
              <% const pct = s.capacity > 0 ? Math.round(s.current_occupancy / s.capacity * 100) : 0; %>
              <div class="progress-bar bg-<%= pct >= 90 ? 'danger' : pct >= 70 ? 'warning' : 'success' %> rounded-pill"
                style="width: <%= pct %>%"></div>
            </div>
            <span class="text-muted" style="font-size:0.72rem;"><%= pct %>% full</span>
          </div>

          <!-- Facilities -->
          <% if (s.facilities) { %>
          <div class="mb-3 d-flex flex-wrap gap-1">
            <% s.facilities.split(',').forEach(f => { %>
              <span class="badge bg-light text-dark border" style="font-size:0.7rem;">
                <%= f.trim() === 'Food' ? '🍛' : f.trim() === 'Water' ? '💧' : f.trim() === 'Medical' ? '🏥' : f.trim() === 'Beds' ? '🛏️' : f.trim() === 'Toilets' ? '🚻' : f.trim() === 'Heating' ? '♨️' : '✓' %>
                <%= f.trim() %>
              </span>
            <% }) %>
          </div>
          <% } %>

          <div class="d-flex justify-content-between align-items-center">
            <% if (s.contact) { %>
              <a href="tel:<%= s.contact.replace(/\D/g,'') %>" class="btn btn-sm btn-outline-success rounded-pill">
                <i class="bi bi-telephone me-1"></i><%= s.contact %>
              </a>
            <% } %>
            <% if (user && user.role === 'admin') { %>
              <form action="/shelters/<%= s.id %>/occupancy" method="POST" class="d-flex gap-1 ms-auto">
                <input type="number" name="current_occupancy" value="<%= s.current_occupancy %>" min="0" max="<%= s.capacity %>"
                  class="form-control form-control-sm rounded-3" style="width:70px;">
                <button type="submit" class="btn btn-sm btn-primary rounded-3">Update</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>
